{
  "name": "zkvanguard",
  "version": "0.2.0",
  "description": "AI-managed crypto vault platform on Sui mainnet — Polymarket-alpha vault (lead product), private hedges, and private portfolio creator. Seven autonomous AI agents, prediction-market signals fused per asset, ZK-attested decisions, BlueFin perp execution. Protocol fees + tiered subscription revenue.",
  "author": "ZkVanguard Team",
  "license": "Apache-2.0",
  "keywords": [
    "sui",
    "ai-agents",
    "prediction-markets",
    "polymarket",
    "defi",
    "vault",
    "zk-proofs",
    "bluefin",
    "web3"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ZkVanguard/ZkVanguard.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "prepare": "husky install",
    "security:scan": "node scripts/security-scan.cjs",
    "security:supply-chain": "node scripts/verify-supply-chain.cjs",
    "prebuild": "node scripts/security-scan.cjs && node scripts/verify-supply-chain.cjs",
    "clean": "rimraf dist coverage .hardhat cache",
    "compile": "hardhat compile",
    "compile:circuits": "bun run scripts/utils/generate-circuits.ts",
    "test": "cross-env ZK_PYTHON_ENABLED=true ZK_PYTHON_API_URL=http://127.0.0.1:8000 bun test .test.ts --timeout 30000 --verbose",
    "test:agents": "bun test test/agents",
    "test:integration": "bun test test/integration",
    "test:contracts": "hardhat test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test:debug": "DEBUG=true bun test --verbose",
    "test:ci": "bun test --coverage",
    "lint": "bun run lint:contracts && bun run lint:ts",
    "lint:contracts": "solhint 'contracts/**/*.sol'",
    "lint:ts": "eslint . --ext .ts,.tsx",
    "lint:fix": "bun run lint:contracts -- --fix && bun run lint:ts -- --fix",
    "format": "prettier --write '**/*.{ts,tsx,sol,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,sol,json,md}'",
    "typecheck": "tsc --noEmit",
    "deploy:testnet": "hardhat run scripts/deploy/deploy-contracts.ts --network cronos-testnet",
    "deploy:mainnet": "hardhat run scripts/deploy/deploy-contracts.ts --network cronos-mainnet",
    "verify:testnet": "hardhat run scripts/deploy/verify-contracts.ts --network cronos-testnet",
    "verify:mainnet": "hardhat run scripts/deploy/verify-contracts.ts --network cronos-mainnet",
    "agents:start": "bun run agents/core/LeadAgent.ts",
    "agents:init": "bun run scripts/setup/setup-agents.ts",
    "agents:dev": "bun --watch run agents/core/LeadAgent.ts",
    "start:next": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "fund:wallets": "bun run scripts/setup/fund-wallets.ts",
    "translate": "bun run scripts/translate-whitepaper.ts",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "build:full": "bun run compile && bun run build",
    "start": "bun run agents:start"
  },
  "overrides": {
    "axios": "^1.18.1",
    "lodash": "^4.17.21",
    "form-data": "^4.0.6",
    "fast-xml-parser": "^5.3.0",
    "fast-uri": "^3.1.0",
    "minimatch": "^9.0.5",
    "path-to-regexp": "^6.3.0",
    "picomatch": "^4.0.0",
    "socket.io-parser": "^4.2.6"
  },
  "resolutions": {
    "axios": "^1.18.1",
    "lodash": "^4.17.21",
    "form-data": "^4.0.6",
    "fast-xml-parser": "^5.3.0",
    "fast-uri": "^3.1.0",
    "minimatch": "^9.0.5",
    "path-to-regexp": "^6.3.0",
    "picomatch": "^4.0.0",
    "socket.io-parser": "^4.2.6"
  },
  "dependencies": {
    "@bluefin-exchange/bluefin7k-aggregator-sdk": "^5.5.1",
    "@bluefin-exchange/pro-sdk": "^1.13.0",
    "@crypto.com/ai-agent-client": "^1.0.2",
    "@crypto.com/developer-platform-client": "^1.1.2",
    "@crypto.com/facilitator-client": "^1.0.4",
    "@heroicons/react": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@mysten/dapp-kit": "^0.14.0",
    "@mysten/sui": "^1.0.0",
    "@neondatabase/serverless": "^0.9.5",
    "@noble/hashes": "^2.0.1",
    "@oasisprotocol/sapphire-paratime": "^2.3.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "@pythnetwork/pyth-sui-js": "^3.0.0",
    "@shazow/whatsabi": "^0.25.0",
    "@tanstack/react-query": "^5.90.12",
    "@tetherto/wdk": "^1.0.0-beta.6",
    "@upstash/qstash": "^2.9.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vvs-finance/swap-sdk": "^0.0.5",
    "buffer": "^6.0.3",
    "chart.js": "^4.5.1",
    "critters": "^0.0.25",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "eventsource": "^4.1.0",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.303.0",
    "next": "^14.2.35",
    "next-intl": "^4.7.0",
    "next-themes": "^0.2.1",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "redis": "^4.6.12",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "viem": "^2.42.0",
    "ws": "^8.16.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "openai": "^4.77.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.2",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.4",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "@playwright/test": "^1.40.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^5.2.3",
    "@types/eventsource": "^3.0.0",
    "@types/jest": "^29.5.11",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "autoprefixer": "^10.4.16",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "eslint-config-prettier": "^9.1.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.27.2",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.9",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "prettier-plugin-solidity": "^1.3.1",
    "rimraf": "^5.0.5",
    "solhint": "^4.1.1",
    "solidity-coverage": "^0.8.5",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.sol": [
      "solhint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "overrides": [
      {
        "files": "*.sol",
        "options": {
          "printWidth": 120,
          "tabWidth": 4,
          "useTabs": false,
          "singleQuote": false,
          "bracketSpacing": false
        }
      }
    ]
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "prettier"
    ],
    "plugins": [
      "@typescript-eslint"
    ],
    "env": {
      "node": true,
      "es2021": true
    },
    "rules": {
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ]
    }
  }
}
