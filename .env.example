# Environment Configuration
NODE_ENV=development

# Network Configuration
CRONOS_TESTNET_RPC=https://evm-t3.cronos.org/
CRONOS_MAINNET_RPC=https://evm.cronos.org/

# Hedera (EVM-compatible) RPC endpoints and deployer key
HEDERA_TESTNET_RPC_URL=
HEDERA_MAINNET_RPC_URL=
HEDERA_PRIVATE_KEY=
HEDERA_TESTNET_CHAIN_ID=296
HEDERA_MAINNET_CHAIN_ID=295

# Oasis Sapphire Network Configuration (Confidential EVM ParaTime)
OASIS_SAPPHIRE_TESTNET_RPC=https://testnet.sapphire.oasis.io
OASIS_SAPPHIRE_MAINNET_RPC=https://sapphire.oasis.io

# Oasis Emerald Network Configuration (Public EVM ParaTime)
OASIS_EMERALD_TESTNET_RPC=https://testnet.emerald.oasis.io
OASIS_EMERALD_MAINNET_RPC=https://emerald.oasis.io

# Private Keys (DO NOT COMMIT REAL KEYS)
PRIVATE_KEY=your_private_key_here
DEPLOYER_PRIVATE_KEY=your_deployer_key_here

# API Keys
CRONOSCAN_API_KEY=your_cronoscan_api_key
COINMARKETCAP_API_KEY=your_cmc_api_key

# Crypto.com AI SDK & Developer Platform
# Get your API key from: https://developers.zkevm.cronos.org/user/apikeys
# Used for: AI Agent, Developer Platform Client, on-chain data queries
CRYPTOCOM_DEVELOPER_API_KEY=your_developer_api_key
DASHBOARD_API_KEY=your_developer_api_key
CRYPTOCOM_API_SECRET=your_api_secret
EXPLORER_API_KEY=your_explorer_api_key

# =============================================================================
# AI PROVIDERS (Priority Order - First available is used)
# =============================================================================
# Priority 1: Crypto.com AI (Native to ecosystem - recommended)
#   - Set CRYPTOCOM_DEVELOPER_API_KEY above
#
# Priority 2: ASI API (Fetch.ai's ASI:One - Production AI)
#   - Get your API key from: https://asi1.ai/
#   - Works with Crypto.com AI SDK as backend
#   - Models: asi1-mini (balanced), asi1-fast, asi1-extended, asi1-agentic
ASI_API_KEY=your_asi_one_api_key_here
ASI_MODEL=asi1-mini
#
# Priority 3: OpenAI (Enterprise-grade, scalable)
OPENAI_API_KEY=your_openai_api_key_here
#
# Priority 4: Anthropic Claude (Safety-focused, enterprise-grade)
ANTHROPIC_API_KEY=your_anthropic_claude_api_key
#
# Priority 5: Ollama (FREE, LOCAL, SECURE - NO DATA LEAVES YOUR SERVER)
#   - Install from: https://ollama.ai
#   - Run: ollama pull qwen2.5:7b
#   - No API key needed - runs completely locally with CUDA acceleration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
#
# Recommended models for DeFi/Financial platforms:
#   - qwen2.5:7b       (RECOMMENDED - best for math, finance, reasoning)
#   - deepseek-r1:8b   (advanced reasoning, financial analysis)
#   - mistral:7b       (general purpose, fast inference)
# =============================================================================

# Optional: Other AI providers (for multi-LLM support)
GOOGLE_API_KEY=your_google_gemini_api_key
XAI_API_KEY=your_xai_grok_api_key

# x402 Configuration
X402_FACILITATOR_URL=https://api.x402.io
X402_API_KEY=your_x402_api_key

# MCP Server
MCP_SERVER_URL=https://mcp.crypto.com/market-data/mcp
MCP_API_KEY=your_mcp_api_key

# dApp Integrations
VVS_ROUTER_ADDRESS=0x145863Eb42Cf62847A6Ca784e6416C1682b1b2Ae

# Moonlander Perpetuals (for hedging)
# Get API keys from: https://moonlander.trade
# Used by: HedgingAgent, /api/agents/hedging/execute
MOONLANDER_API_URL=https://api.moonlander.io
MOONLANDER_PRIVATE_KEY=your_moonlander_trading_wallet_private_key
NEXT_PUBLIC_MOONLANDER_API=https://api.moonlander.io
NEXT_PUBLIC_MOONLANDER_API_KEY=your_moonlander_api_key
NEXT_PUBLIC_MOONLANDER_API_SECRET=your_moonlander_api_secret

# Cronos Testnet RPC for Moonlander trading
NEXT_PUBLIC_CRONOS_TESTNET_RPC=https://evm-t3.cronos.org

# =============================================================================
# SUI NETWORK CONFIGURATION
# =============================================================================
# SUI Network (testnet | mainnet)
SUI_NETWORK=mainnet
SUI_MAINNET_RPC=https://fullnode.mainnet.sui.io:443
SUI_TESTNET_RPC=https://fullnode.testnet.sui.io:443

# SUI Contract Addresses (Mainnet) - Populate after deployment
# Run: bun run deploy:sui:mainnet to get these values
NEXT_PUBLIC_SUI_PACKAGE_ID=
NEXT_PUBLIC_SUI_RWA_MANAGER_STATE=
NEXT_PUBLIC_SUI_ZK_VERIFIER_STATE=
NEXT_PUBLIC_SUI_PAYMENT_ROUTER_STATE=
NEXT_PUBLIC_SUI_ZK_PROXY_VAULT_STATE=
NEXT_PUBLIC_SUI_ADMIN_CAP=
NEXT_PUBLIC_SUI_FEE_MANAGER_CAP=
NEXT_PUBLIC_SUI_COMMUNITY_POOL_STATE=

# SUI Pool Admin Key (Ed25519 private key for executing swaps)
# Used by: CetusAggregatorService.executeSwap, cron route
SUI_POOL_ADMIN_KEY=0x...or_suiprivkey1...

# SUI Mainnet Community Pool Overrides (if different from above)
# These take priority over NEXT_PUBLIC_SUI_PACKAGE_ID etc. for mainnet
NEXT_PUBLIC_SUI_MAINNET_PACKAGE_ID=
NEXT_PUBLIC_SUI_MAINNET_ADMIN_CAP=
NEXT_PUBLIC_SUI_MAINNET_FEE_MANAGER_CAP=
NEXT_PUBLIC_SUI_MAINNET_COMMUNITY_POOL_STATE=

# SUI USDC Pool (mainnet)
NEXT_PUBLIC_SUI_MAINNET_USDC_POOL_PACKAGE_ID=
NEXT_PUBLIC_SUI_MAINNET_USDC_POOL_STATE=

# SUI USDC Pool (testnet)
NEXT_PUBLIC_SUI_USDC_POOL_PACKAGE_ID=
NEXT_PUBLIC_SUI_USDC_POOL_STATE=

# BlueFin Perpetuals on SUI Network
# BlueFin uses SUI wallet signature authentication (NOT API keys)
# Used by: /api/agents/hedging/bluefin, BluefinService
# Get your wallet private key from SUI Wallet export
BLUEFIN_PRIVATE_KEY=suiprivkey1...your_sui_wallet_ed25519_private_key
BLUEFIN_WALLET_ADDRESS=0x...your_sui_wallet_address
BLUEFIN_NETWORK=mainnet
BLUEFIN_USE_MOCK=false

DELPHI_CONTRACT_ADDRESS=0x...

# Database (PostgreSQL - Neon free tier recommended)
# Get free database at: https://neon.tech (512MB free)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/zkvanguard_analytics?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/zkvanguard_analytics?sslmode=require

# Analytics (GDPR compliant)
ANALYTICS_ADMIN_KEY=your_random_admin_key_here

# Legacy local DB config (optional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zkvanguard
DB_USER=zkvanguard_user
DB_PASSWORD=your_db_password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Agent Configuration
AGENT_LOG_LEVEL=debug
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT=30000

# ZK Configuration
ZK_TRUSTED_SETUP_PATH=./zk/trusted-setup
ZK_CIRCUIT_PATH=./zk/circuits

# ZK-STARK API Configuration
# Local development: http://localhost:8000
# Production: https://zk-api.starknova.xyz (via Cloudflare Tunnel)
ZK_API_URL=https://zk-api.starknova.xyz
NEXT_PUBLIC_ZK_API_URL=https://zk-api.starknova.xyz
ZK_PYTHON_TIMEOUT=120000

# Set to 'true' to use mock proofs when ZK server is unavailable (for CI/testing)
ZK_FALLBACK_TO_MOCK=false

# Frontend
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_CHAIN_ID=338

# Simulator
SIMULATOR_PORT=3001
SIMULATOR_DB_PATH=./simulator/data

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Gas Configuration
GAS_PRICE_MULTIPLIER=1.1
MAX_GAS_LIMIT=8000000

# Testing
FORK_CRONOS=false
FORK_BLOCK_NUMBER=0
REPORT_GAS=true

# Oasis Sapphire Contract Addresses (Testnet)
NEXT_PUBLIC_OASIS_ZKVERIFIER_ADDRESS=
NEXT_PUBLIC_OASIS_RWAMANAGER_ADDRESS=
NEXT_PUBLIC_OASIS_PAYMENT_ROUTER_ADDRESS=
NEXT_PUBLIC_OASIS_CONFIDENTIAL_ZK_VERIFIER=
NEXT_PUBLIC_OASIS_GASLESS_COMMITMENT_VERIFIER=
NEXT_PUBLIC_OASIS_HEDGE_EXECUTOR_ADDRESS=

# Oasis Sapphire Contract Addresses (Mainnet)
NEXT_PUBLIC_OASIS_MAINNET_ZKVERIFIER_ADDRESS=
NEXT_PUBLIC_OASIS_MAINNET_RWAMANAGER_ADDRESS=
NEXT_PUBLIC_OASIS_MAINNET_PAYMENT_ROUTER_ADDRESS=
NEXT_PUBLIC_OASIS_MAINNET_CONFIDENTIAL_ZK_VERIFIER=
NEXT_PUBLIC_OASIS_MAINNET_GASLESS_COMMITMENT_VERIFIER=
NEXT_PUBLIC_OASIS_MAINNET_HEDGE_EXECUTOR_ADDRESS=

# Oasis Emerald Contract Addresses (Testnet)
NEXT_PUBLIC_EMERALD_ZKVERIFIER_ADDRESS=
NEXT_PUBLIC_EMERALD_RWAMANAGER_ADDRESS=
NEXT_PUBLIC_EMERALD_PAYMENT_ROUTER_ADDRESS=
NEXT_PUBLIC_EMERALD_GASLESS_COMMITMENT_VERIFIER=
NEXT_PUBLIC_EMERALD_HEDGE_EXECUTOR_ADDRESS=

# Oasis Emerald Contract Addresses (Mainnet)
NEXT_PUBLIC_EMERALD_MAINNET_ZKVERIFIER_ADDRESS=
NEXT_PUBLIC_EMERALD_MAINNET_RWAMANAGER_ADDRESS=
NEXT_PUBLIC_EMERALD_MAINNET_PAYMENT_ROUTER_ADDRESS=
NEXT_PUBLIC_EMERALD_MAINNET_GASLESS_COMMITMENT_VERIFIER=
NEXT_PUBLIC_EMERALD_MAINNET_HEDGE_EXECUTOR_ADDRESS=

# Security
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# =============================================================================
# QSTASH / UPSTASH CONFIGURATION (Cron Jobs & Message Queue)
# =============================================================================
# Get credentials from: https://console.upstash.com/qstash
# Used for: Scheduled cron jobs (hedge-monitor, auto-rebalance, liquidation-guard)
# Free tier: 500 messages/day, 100 requests/day

# QStash API Token (for publishing messages/schedules)
QSTASH_TOKEN=your_qstash_token_here

# QStash Signing Keys (for verifying incoming webhook signatures)
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key_for_rotation

# Fallback CRON_SECRET for internal/manual cron calls
# Generate: openssl rand -base64 32
CRON_SECRET=your_secure_cron_secret_here

# Monitoring
SENTRY_DSN=
GRAFANA_URL=
PROMETHEUS_PORT=9090
